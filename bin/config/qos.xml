<?xml version="1.0" encoding="UTF-8"?>
<qos>
    <transport type="udp" />
    <domainId>0</domainId>

    <!--
      同一 domain 内默认使用统一端口公式:
      bindPort = basePort + domainId * domainPortOffset
      不同机器使用同一端口不会冲突，广播发现会把真实节点地址同步给对端。
    -->
    <enableDomainPortMapping>true</enableDomainPortMapping>
    <basePort>26000</basePort>
    <domainPortOffset>20</domainPortOffset>

    <historyDepth>8</historyDepth>
    <deadlineMs>1000</deadlineMs>
    <reliable>false</reliable>

    <topicQos key="LTopType::HANDLE_TOPIC" historyDepth="16" deadlineMs="400" />
    <topicQos group="LCoreRuntime::" historyDepth="4" deadlineMs="800" />
</qos>
